---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "baconpaul",
  description = "Open-source music software, creative-commons music, and miscellany by Paul Walker — baconpaul.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
  </head>
  <body>
    <header class="site-head">
      <div class="wrap">
        <a class="wordmark" href="/">baconpaul.org</a>
        <nav class="site-nav">
          <a href="https://surge-synth-team.org" target="_blank" rel="noopener">
            Surge Synth Team
          </a>
          <a href="/sidequests/">Sidequests</a>
          <a href="/music/">Music</a>
          <a href="https://cleveraudio.org" target="_blank" rel="noopener">
            CLAP
          </a>
          <a href="/interviews/">Interviews</a>
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-foot">
      <div class="wrap">
        <a class="gh" href="https://github.com/baconpaul" aria-label="GitHub">
          <svg viewBox="0 0 24 24" width="24" height="24" aria-hidden="true">
            <path
              fill="currentColor"
              d="M12 .5C5.37.5 0 5.78 0 12.29c0 5.21 3.44 9.63 8.21 11.19.6.11.82-.25.82-.56 0-.28-.01-1.02-.02-2-3.34.71-4.04-1.58-4.04-1.58-.55-1.37-1.34-1.74-1.34-1.74-1.09-.73.08-.72.08-.72 1.21.08 1.84 1.22 1.84 1.22 1.07 1.8 2.81 1.28 3.5.98.11-.76.42-1.28.76-1.57-2.67-.3-5.47-1.31-5.47-5.84 0-1.29.47-2.34 1.24-3.17-.12-.3-.54-1.52.12-3.16 0 0 1.01-.32 3.3 1.21.96-.26 1.98-.39 3-.4 1.02.01 2.04.14 3 .4 2.29-1.53 3.3-1.21 3.3-1.21.66 1.64.24 2.86.12 3.16.77.83 1.24 1.88 1.24 3.17 0 4.54-2.81 5.54-5.49 5.83.43.36.81 1.08.81 2.18 0 1.58-.01 2.85-.01 3.24 0 .31.21.68.83.56C20.56 21.91 24 17.5 24 12.29 24 5.78 18.63.5 12 .5z"
            ></path>
          </svg>
        </a>
        <p class="copyright">
          © {new Date().getFullYear()} Paul Walker. Site content licensed under
          <a href="https://creativecommons.org/licenses/by/4.0/">CC BY 4.0</a>.
        </p>
      </div>
    </footer>
  </body>
</html>
